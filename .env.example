# =============================================================================
# LOCAL — copy to .env.local (gitignored). Used by `pnpm dev` + Vite.
# =============================================================================

# Canonical site URL (no trailing slash). Injected into index.html for og:url, og:image, Twitter card, and canonical link.
# Example: https://www.tandrapeters.com
# VITE_SITE_URL=

# Contact form: production origin ONLY (e.g. https://www.yoursite.com).
# No path — not .../api/contact. Vite proxies /api/* to this host.
# VITE_CONTACT_API_URL=

# Wally testimonials widget ID (optional; Testimonials has a default if unset).
# VITE_WALLY_WIDGET_ID=

# Optional: AI Studio / Gemini if you wire @google/genai in the app.
# GEMINI_API_KEY=

# =============================================================================
# VERCEL — Project → Settings → Environment Variables (all environments you use)
# =============================================================================

# Required for /api/contact → Attio (People record assert by email).
# ATTIO_API_TOKEN=

# Optional. Comma-separated exact Origin values, e.g.:
#   https://yoursite.com,https://www.yoursite.com,http://localhost:5173
# If omitted, any Origin is allowed (fine for early setup; tighten for production).
# Local dev with VITE_CONTACT_API_URL needs your live API to allow http://localhost:5173 here.
# ALLOWED_ORIGINS=

# Optional: override Wally widget in the built site (same as local VITE_ var).
# VITE_WALLY_WIDGET_ID=

# =============================================================================
# Notes
# =============================================================================
# - VITE_* vars are embedded in client JS at build time on Vercel.
# - ATTIO_API_TOKEN and ALLOWED_ORIGINS are server-only (api/contact.ts); never prefix with VITE_.
