# =============================================================================
# LOCAL — copy to `.env.local` at repo root (gitignored). Used by `pnpm dev` + Vite.
# =============================================================================

# Canonical site URL (no trailing slash). OG/Twitter meta, structured data, and social share links while developing locally (otherwise Facebook/LinkedIn get localhost and break).
# VITE_SITE_URL=https://www.tandra.me

# Contact form: production origin ONLY (e.g. https://www.tandra.me). Vite proxies only `/api/contact`.
# VITE_CONTACT_API_URL=https://www.tandra.me

# Elfsight Google Reviews widget UUID (class="elfsight-app-…").
# VITE_ELFSIGHT_WIDGET_ID=

# Sanity (public IDs are fine in the bundle; project/dataset are also in src/sanity/projectDetails.ts)
# Studio URL for stega “edit in Studio” links when not in Presentation iframe.
# VITE_SANITY_STUDIO_URL=http://localhost:3333
# Optional: force stega in the browser (normally only in Presentation iframe).
# VITE_SANITY_STEGA=true
# Viewer token — required so Presentation preview can read drafts (create in sanity.io/manage → API → Tokens).
# VITE_SANITY_API_READ_TOKEN=

# PostHog (public project key + ingestion host)
# VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# First-party proxy example: https://t.tandra.me — set VITE_PUBLIC_POSTHOG_UI_HOST if toolbar/replay needs it.
# VITE_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# Gemini (Sanity AI images): required for `pnpm dev` → POST /api/gemini/generate-image (see plugins/viteGeminiDevApi.ts). Also set on Vercel for the same route.
# GEMINI_API_KEY=
# Optional: require X-API-Key from Studio (must match if set).
# GEMINI_PLUGIN_API_KEY=

# =============================================================================
# STUDIO — `studio-tandra-peters/.env.local` (see studio-tandra-peters/.env.example)
# =============================================================================
# SANITY_API_WRITE_TOKEN — only for `pnpm seed` in the studio folder (never in Vite, never on Vercel unless you add server writes).
# SANITY_STUDIO_PREVIEW_URL — same origin/port as this app’s `pnpm dev`.

# =============================================================================
# VERCEL — Project → Settings → Environment Variables
# =============================================================================

# Required for /api/contact → Attio.
# ATTIO_API_TOKEN=

# Comma-separated exact Origins, e.g. https://www.tandra.me,http://localhost:3000
# ALLOWED_ORIGINS=

# Same VITE_* as above for production preview builds.
# VITE_SITE_URL=
# VITE_CONTACT_API_URL=
# VITE_ELFSIGHT_WIDGET_ID=
# VITE_GOOGLE_CLIENT_ID=
# VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
# VITE_PUBLIC_POSTHOG_HOST=
# VITE_PUBLIC_POSTHOG_UI_HOST=
# VITE_SANITY_STUDIO_URL=https://your-deployed-studio.sanity.studio

# SEO dashboard server analytics:
# POSTHOG_PROJECT_ID=
# POSTHOG_PERSONAL_API_KEY=
# Optional app host for private PostHog API calls (defaults to us.posthog.com or is derived from VITE_PUBLIC_POSTHOG_HOST).
# POSTHOG_API_HOST=https://us.posthog.com
# Optional AI summary for the SEO dashboard.
# GEMINI_API_KEY=
# Restrict `/seo` to exact Google account emails and/or a Google Workspace domain.
# GOOGLE_ALLOWED_EMAILS=you@example.com,teammate@example.com
# GOOGLE_ALLOWED_DOMAIN=example.com

# =============================================================================
# Notes
# =============================================================================
# - VITE_* are inlined at build time on Vercel.
# - ATTIO_API_TOKEN and ALLOWED_ORIGINS are server-only (api/contact.ts); never prefix with VITE_.
# - After rotating SANITY_API_WRITE_TOKEN, run from studio-tandra-peters: `pnpm seed`
