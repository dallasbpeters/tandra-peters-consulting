# Copy to `.env.local` (gitignored). Never commit real tokens.
#
# Create / rotate tokens: https://www.sanity.io/manage → Project → API → Tokens
# SANITY_API_WRITE_TOKEN — required for `pnpm seed` (loaded from this file automatically).
SANITY_API_WRITE_TOKEN=

# Presentation tool: must match the origin where the site runs (Vite default port 3000 in this repo).
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000

# Gemini AI Images (sanity-plugin-gemini-ai-images): absolute URL to the site’s generate endpoint.
# Vite does not serve /api/* locally — use `vercel dev` from the repo root, or your deployed site URL.
SANITY_STUDIO_GEMINI_API_URL=http://localhost:3000/api/gemini/generate-image
