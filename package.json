{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:all": "concurrently -k -n site,studio -c cyan,magenta \"pnpm dev\" \"pnpm --dir studio-tandra-peters dev\"",
    "build": "vite build",
    "build:vercel": "node scripts/build-vercel.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "stylelint": "stylelint \"**/*.{css,js}\"",
    "format": "exec prettier . --write",
    "check:lint": "eslint \"**/*.{css,js}\"",
    "check:lint:fix": "eslint \"**/*.{css,js}\" --fix",
    "check:types": "tsc --noEmit \"**/*.{css,js}\"",
    "check:types:fix": "tsc --noEmit --fix \"**/*.{css,js}\""
  },
